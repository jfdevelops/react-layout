{
  "name": "view-map-workspace",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --filter ./packages/core dev",
    "dev:basic-example": "pnpm --filter basic-example dev",
    "build": "pnpm --filter ./packages/core build",
    "build:examples": "pnpm --filter basic-example build",
    "typecheck": "pnpm --filter ./packages/core typecheck",
    "typecheck:examples": "pnpm --filter basic-example typecheck",
    "test": "pnpm --filter ./packages/core test",
    "test:watch": "pnpm --filter ./packages/core test:watch",
    "test:ui": "pnpm --filter ./packages/core test:ui",
    "test:coverage": "pnpm --filter ./packages/core test:coverage",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "preview": "pnpm --filter ./packages/core preview"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0"
  }
}
